 159          void main()
 160          {
 161   1          Timer0_Init();
 162   1          while(1)
 163   1          {
 164   2              // ====================== 核心逻辑 ======================
 165   2              if(MusicFinish == 0)  // 没播完：正常播放
 166   2              {
 167   3                  FreqSelect = Music_2[MusicSelect];
